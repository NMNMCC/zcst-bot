{
  "name": "zcst-bot",
  "version": "1.0.0",
  "description": "ZCST Fee Bot - Dormitory utility fee monitoring and recharge bot",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "wrangler dev",
    "deploy": "wrangler deploy",
    "start": "wrangler dev",
    "cf-typegen": "wrangler types",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "wrangler d1 migrations apply zcst-bot-db",
    "db:migrate:local": "wrangler d1 migrations apply zcst-bot-db --local",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@cloudflare/puppeteer": "^0.0.14",
    "@effect/platform": "^0.94.5",
    "@effect/platform-browser": "^0.74.0",
    "@grammyjs/auto-retry": "^2.0.0",
    "@grammyjs/conversations": "^2.1.1",
    "drizzle-orm": "^0.44.2",
    "effect": "^3.17.9",
    "grammy": "^1.36.3"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20250917.0",
    "@types/node": "^25.5.0",
    "drizzle-kit": "^0.31.4",
    "typescript": "^5.5.2",
    "wrangler": "^4.72.0"
  }
}
